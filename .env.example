# Week 13 Dockerized KMS/RAG configuration.
# Copy to .env before running docker-compose.
# Never commit .env or real API keys.

# PostgreSQL / Odoo service configuration
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
ODOO_DB=cityrise_w13
ODOO_HOST=db
ODOO_PORT=5432
ODOO_USER=odoo
ODOO_PASSWORD=odoo
ODOO_INIT_MODULES=cityrise_ai_assistant,kms_knowledge
ODOO_LOGIN=admin
ODOO_LOGIN_PASSWORD=admin
ODOO_DATA_LIMIT=50
ODOO_HTTP_PORT=8069

# Streamlit chatbot service configuration
CHATBOT_PORT=8501
VECTOR_PERSIST_DIR=/app/chroma_db
VECTOR_COLLECTION=kms_collection
RAG_PROVIDER=local
RAG_AUDIENCE=public
RAG_ALLOW_ROLE_SWITCH=false
RAG_TOP_K=4
RAG_TEMPERATURE=0.2
RAG_MAX_CONTEXT_CHARS=4000

# Optional local Ollama provider.
# If Ollama runs on the host machine, Docker Desktop can normally reach it via host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b

# Optional cloud providers. Leave blank unless the instructor asks you to test them.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
