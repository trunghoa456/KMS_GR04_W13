<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cityrise_ai_conversation_list" model="ir.ui.view">
        <field name="name">cityrise.ai.conversation.list</field>
        <field name="model">cityrise.ai.conversation</field>
        <field name="arch" type="xml">
            <list string="AI Conversations">
                <field name="create_date"/>
                <field name="audience"/>
                <field name="confidence"/>
                <field name="intent"/>
                <field name="source_summary"/>
                <field name="user_id"/>
                <field name="contact_name"/>
                <field name="contact_phone"/>
                <field name="contact_email"/>
                <field name="lead_id"/>
            </list>
        </field>
    </record>

    <record id="view_cityrise_ai_conversation_form" model="ir.ui.view">
        <field name="name">cityrise.ai.conversation.form</field>
        <field name="model">cityrise.ai.conversation</field>
        <field name="arch" type="xml">
            <form string="AI Conversation">
                <sheet>
                    <group>
                        <group>
                            <field name="audience"/>
                            <field name="confidence"/>
                            <field name="intent"/>
                            <field name="source_summary"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                        </group>
                        <group>
                            <field name="contact_name"/>
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Question">
                            <field name="question"/>
                        </page>
                        <page string="Answer">
                            <field name="answer"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cityrise_ai_conversation_search" model="ir.ui.view">
        <field name="name">cityrise.ai.conversation.search</field>
        <field name="model">cityrise.ai.conversation</field>
        <field name="arch" type="xml">
            <search string="AI Conversations">
                <field name="question"/>
                <field name="answer"/>
                <field name="contact_name"/>
                <field name="contact_email"/>
                <filter name="public" string="Public" domain="[('audience', '=', 'public')]"/>
                <filter name="internal" string="Internal" domain="[('audience', '=', 'internal')]"/>
                <filter name="lead" string="Lead Created" domain="[('lead_id', '!=', False)]"/>
                <group>
                    <filter name="group_audience" string="Audience" domain="[]" context="{'group_by': 'audience'}"/>
                    <filter name="group_confidence" string="Confidence" domain="[]" context="{'group_by': 'confidence'}"/>
                    <filter name="group_intent" string="Intent" domain="[]" context="{'group_by': 'intent'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_cityrise_ai_open" model="ir.actions.act_url">
        <field name="name">AI Assistant</field>
        <field name="url">/ai-assistant</field>
        <field name="target">self</field>
    </record>

    <record id="action_cityrise_ai_backend_iframe" model="ir.actions.client">
        <field name="name">AI Chatbot</field>
        <field name="tag">cityrise_ai_assistant.iframe_action</field>
    </record>

    <record id="action_cityrise_ai_conversations" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">cityrise.ai.conversation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_cityrise_ai_root" name="AI" sequence="7" action="action_cityrise_ai_backend_iframe" web_icon="cityrise_ai_assistant,static/description/icon.svg"/>
    <menuitem id="menu_cityrise_ai_assistant" name="AI Chatbot" parent="menu_cityrise_ai_root" action="action_cityrise_ai_backend_iframe" sequence="10"/>
    <menuitem id="menu_cityrise_ai_conversations" name="Conversations" parent="menu_cityrise_ai_root" action="action_cityrise_ai_conversations" sequence="20" groups="base.group_user"/>
</odoo>
