<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="website_menu_ai_assistant" model="website.menu">
        <field name="name">AI Assistant</field>
        <field name="url">/ai-assistant</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" eval="45"/>
    </record>

    <template id="ai_assistant_widget" name="CityRise AI Assistant Widget">
        <section
            t-att-class="'cityrise-ai cityrise-ai--embedded' if embedded else 'cityrise-ai'"
            t-att-data-internal="'1' if is_internal else '0'"
            t-att-data-role="role_label"
            t-att-data-endpoint="endpoint">
            <div class="cityrise-ai-shell">
                <div class="cityrise-ai-header">
                    <div>
                        <p class="cityrise-ai-kicker">CityRise</p>
                        <h1>AI Assistant</h1>
                    </div>
                    <span class="cityrise-ai-badge" t-esc="audience_label"/>
                </div>
                <div class="cityrise-ai-thread" aria-live="polite">
                    <div class="cityrise-ai-message cityrise-ai-message-bot">
                        <p t-if="is_internal">
                            Xin chao, minh dang chay trong Odoo voi quyen <t t-esc="audience_label"/>. Ban co the hoi ve knowledge, sales, purchase, tickets, nhan vien va du lieu CityRise theo phan quyen.
                        </p>
                        <p t-else="">
                            Xin chao, minh chi ho tro thong tin cong khai ve san pham CityRise, gia niem yet, website va nhu cau tu van. Du lieu noi bo duoc bao ve theo access matrix.
                        </p>
                    </div>
                </div>
                <div class="cityrise-ai-prompts">
                    <t t-if="is_internal">
                        <button type="button" data-question="Tong sales va purchase">Tong sales va purchase</button>
                        <button type="button" data-question="Doanh thu hien tai cua cong ty la bao nhieu?">Doanh thu hien tai</button>
                        <button type="button" data-question="Show me the CEO's salary">CEO salary</button>
                        <button type="button" data-question="Purchase order P00030">Purchase P00030</button>
                    </t>
                    <t t-else="">
                        <button type="button" data-question="Danh sach san pham dang ban">Danh sach san pham</button>
                        <button type="button" data-question="Can ho re nhat la gi?">Can ho re nhat</button>
                        <button type="button" data-question="Can ho tu 10 den 15 ty">10-15 ty</button>
                        <button type="button" data-question="Toi can tu van can ho 90x">Can tu van</button>
                    </t>
                </div>
                <form class="cityrise-ai-form">
                    <textarea name="question" rows="3" placeholder="Nhap cau hoi cua ban..." required="required"></textarea>
                    <div class="cityrise-ai-contact" t-if="not is_internal">
                        <input name="visitor_name" placeholder="Ten cua ban"/>
                        <input name="visitor_phone" placeholder="So dien thoai"/>
                        <input name="visitor_email" placeholder="Email"/>
                    </div>
                    <button type="submit">Gui</button>
                </form>
            </div>
        </section>
    </template>

    <template id="ai_assistant_page" name="CityRise AI Assistant">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <t t-call="cityrise_ai_assistant.ai_assistant_widget"/>
            </div>
        </t>
    </template>

    <template id="ai_assistant_backend_frame" name="CityRise AI Assistant Backend Frame">
        <html>
            <head>
                <title>CityRise AI Assistant</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <t t-call-assets="web.assets_frontend" t-js="false"/>
                <t t-call-assets="web.assets_frontend" t-css="false"/>
            </head>
            <body class="cityrise-ai-frame-body">
                <t t-call="cityrise_ai_assistant.ai_assistant_widget"/>
            </body>
        </html>
    </template>
</odoo>
